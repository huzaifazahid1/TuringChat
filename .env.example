# ────────────────────────────────────────────────────────────────
# TuringChat — environment template
# Copy this file to `.env` and fill in real values.
# ────────────────────────────────────────────────────────────────

# ── Backend
PORT=5000
LOG_LEVEL=info

# ── MongoDB
MONGO_USERNAME=turing
MONGO_PASSWORD=change-me-please
MONGO_DB_NAME=turingchat
# Used internally by `backend` to connect — built from the three above:
#   mongodb://${MONGO_USERNAME}:${MONGO_PASSWORD}@mongo:27017/${MONGO_DB_NAME}?authSource=admin

# ── Redis
REDIS_PASSWORD=redis-change-me

# ── Groq API
# Get one at https://console.groq.com/keys
GROQ_API_KEY=Your_Groq_Api_Key

# ── JWT
# Use 64+ random bytes. Tip: `openssl rand -base64 64`
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS
# In dev: http://localhost:3000
# In prod: https://yourdomain.com (or comma-separated list)
CORS_ORIGIN=http://localhost:3000,http://localhost

# ── Frontend (build-time, baked into the JS bundle)
# In docker-compose this is `http://localhost` (nginx proxies to backend).
# In local dev without nginx, point straight at the backend:
#   NEXT_PUBLIC_API_URL=http://localhost:5000
#   NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_SOCKET_URL=http://localhost

# ── Edge
NGINX_PORT=80
